  "One helper emits debounced in-page updates without a separate JavaScript asset.": {
    "fr": "Un seul helper produit des mises a jour differees dans la page sans fichier JavaScript separe.",
    "ar": "\u064a\u0648\u0644\u062f \u0645\u0633\u0627\u0639\u062f \u0648\u0627\u062d\u062f \u062a\u062d\u062f\u064a\u062b\u0627\u062a \u0645\u0624\u062c\u0644\u0629 \u062f\u0627\u062e\u0644 \u0627\u0644\u0635\u0641\u062d\u0629 \u0645\u0646 \u062f\u0648\u0646 \u0645\u0644\u0641 \u062c\u0627\u0641\u0627\u0633\u0643\u0631\u0628\u062a \u0645\u0646\u0641\u0635\u0644.",
    "ja": "1\u3064\u306e\u30d8\u30eb\u30d1\u30fc\u3067\u3001\u5225\u306e JavaScript \u30a2\u30bb\u30c3\u30c8\u306a\u3057\u306b\u5165\u529b\u306b\u5408\u308f\u305b\u305f\u30da\u30fc\u30b8\u5185\u66f4\u65b0\u3092\u884c\u3048\u307e\u3059\u3002"
  },
  "HTTP Helpers": {
    "fr": "Helpers HTTP",
    "ar": "\u0645\u0633\u0627\u0639\u062f\u0627\u062a HTTP",
    "ja": "HTTP \u30d8\u30eb\u30d1\u30fc"
  },
  "Query fields and routes stay readable without manual buffer clearing in every handler.": {
    "fr": "Les routes et les champs de requete restent lisibles sans reinitialiser les buffers dans chaque handler.",
    "ar": "\u062a\u0628\u0642\u0649 \u0627\u0644\u0645\u0633\u0627\u0631\u0627\u062a \u0648\u062d\u0642\u0648\u0644 \u0627\u0644\u0627\u0633\u062a\u0639\u0644\u0627\u0645 \u0648\u0627\u0636\u062d\u0629 \u0645\u0646 \u062f\u0648\u0646 \u0625\u0639\u0627\u062f\u0629 \u062a\u0647\u064a\u0626\u0629 \u0627\u0644\u0645\u062e\u0627\u0632\u0646 \u0641\u064a \u0643\u0644 \u0645\u0639\u0627\u0644\u062c.",
    "ja": "\u5404\u30cf\u30f3\u30c9\u30e9\u3067\u624b\u52d5\u306e\u30d0\u30c3\u30d5\u30a1\u521d\u671f\u5316\u3092\u3057\u306a\u304f\u3066\u3082\u3001\u30eb\u30fc\u30c8\u3068\u30af\u30a8\u30ea\u51e6\u7406\u3092\u8aad\u307f\u3084\u3059\u304f\u4fdd\u3066\u307e\u3059\u3002"
  },
  "Render Functions": {
    "fr": "Fonctions de rendu",
    "ar": "\u062f\u0648\u0627\u0644 \u0627\u0644\u0639\u0631\u0636",
    "ja": "\u63cf\u753b\u95a2\u6570"
  },
  "Pages are easier to copy when markup is split into small focused C functions.": {
    "fr": "Les pages sont plus faciles a recopier quand le markup est divise en petites fonctions C ciblees.",
    "ar": "\u062a\u0635\u0628\u062d \u0627\u0644\u0635\u0641\u062d\u0627\u062a \u0623\u0633\u0647\u0644 \u0641\u064a \u0627\u0644\u0646\u0633\u062e \u0639\u0646\u062f\u0645\u0627 \u064a\u064f\u0642\u0633\u0651\u064e\u0645 \u0627\u0644\u062a\u0631\u0645\u064a\u0632 \u0625\u0644\u0649 \u062f\u0648\u0627\u0644 C \u0635\u063a\u064a\u0631\u0629 \u0648\u0645\u0631\u0643\u0632\u0629.",
    "ja": "\u30de\u30fc\u30af\u30a2\u30c3\u30d7\u3092\u5c0f\u3055\u304f\u5f79\u5272\u306e\u306f\u3063\u304d\u308a\u3057\u305f C \u95a2\u6570\u306b\u5206\u3051\u308b\u3068\u3001\u30da\u30fc\u30b8\u69cb\u6210\u3092\u305d\u306e\u307e\u307e\u518d\u5229\u7528\u3057\u3084\u3059\u304f\u306a\u308a\u307e\u3059\u3002"
  },
  "Library Features": {
    "fr": "Fonctionnalites de la bibliotheque",
    "ar": "\u0645\u064a\u0632\u0627\u062a \u0627\u0644\u0645\u0643\u062a\u0628\u0629",
    "ja": "\u30e9\u30a4\u30d6\u30e9\u30ea\u306e\u6a5f\u80fd"
  },
  "Live Preview": {
    "fr": "Apercu en direct",
    "ar": "\u0645\u0639\u0627\u064a\u0646\u0629 \u0645\u0628\u0627\u0634\u0631\u0629",
    "ja": "\u30e9\u30a4\u30d6\u30d7\u30ec\u30d3\u30e5\u30fc"
  },
  "This example keeps the page logic in C, lets you switch languages, and updates the preview as you type.": {
    "fr": "Cet exemple garde la logique de page en C, permet de changer de langue et met a jour l'apercu pendant la saisie.",
    "ar": "\u064a\u0628\u0642\u064a \u0647\u0630\u0627 \u0627\u0644\u0645\u062b\u0627\u0644 \u0645\u0646\u0637\u0642 \u0627\u0644\u0635\u0641\u062d\u0629 \u0641\u064a C\u060c \u0648\u064a\u062a\u064a\u062d \u0644\u0643 \u062a\u0628\u062f\u064a\u0644 \u0627\u0644\u0644\u063a\u0627\u062a\u060c \u0648\u064a\u062d\u062f\u062b \u0627\u0644\u0645\u0639\u0627\u064a\u0646\u0629 \u0623\u062b\u0646\u0627\u0621 \u0627\u0644\u0643\u062a\u0627\u0628\u0629.",
    "ja": "\u3053\u306e\u4f8b\u3067\u306f\u30da\u30fc\u30b8\u30ed\u30b8\u30c3\u30af\u3092 C \u306b\u4fdd\u3063\u305f\u307e\u307e\u3001\u8a00\u8a9e\u3092\u5207\u308a\u66ff\u3048\u3064\u3064\u5165\u529b\u306b\u5408\u308f\u305b\u3066\u30d7\u30ec\u30d3\u30e5\u30fc\u3092\u66f4\u65b0\u3067\u304d\u307e\u3059\u3002"
  },
  "Open Full Search Page": {
    "fr": "Ouvrir la page complete de recherche",
    "ar": "\u0627\u0641\u062a\u062d \u0635\u0641\u062d\u0629 \u0627\u0644\u0628\u062d\u062b \u0627\u0644\u0643\u0627\u0645\u0644\u0629",
    "ja": "\u691c\u7d22\u30da\u30fc\u30b8\u5168\u4f53\u3092\u958b\u304f"
  },
  "Typing updates the preview below, and the selected language stays active for both the page and the live search.": {
    "fr": "La saisie met a jour l'apercu ci-dessous, et la langue choisie reste active pour la page et la recherche en direct.",
    "ar": "\u062a\u062d\u062f\u0651\u062b \u0627\u0644\u0643\u062a\u0627\u0628\u0629 \u0627\u0644\u0645\u0639\u0627\u064a\u0646\u0629 \u0623\u062f\u0646\u0627\u0647\u060c \u0648\u062a\u0628\u0642\u0649 \u0627\u0644\u0644\u063a\u0629 \u0627\u0644\u0645\u062e\u062a\u0627\u0631\u0629 \u0645\u0641\u0639\u0644\u0629 \u0644\u0644\u0635\u0641\u062d\u0629 \u0648\u0644\u0644\u0628\u062d\u062b \u0627\u0644\u0645\u0628\u0627\u0634\u0631.",
    "ja": "\u5165\u529b\u3059\u308b\u3068\u4e0b\u306e\u30d7\u30ec\u30d3\u30e5\u30fc\u304c\u66f4\u65b0\u3055\u308c\u3001\u9078\u3093\u3060\u8a00\u8a9e\u306f\u30da\u30fc\u30b8\u5168\u4f53\u3068\u30e9\u30a4\u30d6\u691c\u7d22\u306e\u4e21\u65b9\u3067\u7dad\u6301\u3055\u308c\u307e\u3059\u3002"
  },
  "Type in the search field to preview matching feature cards here.": {
    "fr": "Tapez dans le champ de recherche pour afficher ici les cartes correspondantes.",
    "ar": "\u0627\u0643\u062a\u0628 \u0641\u064a \u062d\u0642\u0644 \u0627\u0644\u0628\u062d\u062b \u0644\u0639\u0631\u0636 \u0628\u0637\u0627\u0642\u0627\u062a \u0627\u0644\u0645\u064a\u0632\u0627\u062a \u0627\u0644\u0645\u0637\u0627\u0628\u0642\u0629 \u0647\u0646\u0627.",
    "ja": "\u691c\u7d22\u6b04\u306b\u5165\u529b\u3059\u308b\u3068\u3001\u3053\u3053\u306b\u4e00\u81f4\u3059\u308b\u6a5f\u80fd\u30ab\u30fc\u30c9\u306e\u30d7\u30ec\u30d3\u30e5\u30fc\u304c\u8868\u793a\u3055\u308c\u307e\u3059\u3002"
  },
  "Matching features for the current query.": {
    "fr": "Fonctionnalites correspondantes pour la requete actuelle.",
    "ar": "\u0627\u0644\u0645\u064a\u0632\u0627\u062a \u0627\u0644\u0645\u0637\u0627\u0628\u0642\u0629 \u0644\u0644\u0627\u0633\u062a\u0639\u0644\u0627\u0645 \u0627\u0644\u062d\u0627\u0644\u064a.",
    "ja": "\u73fe\u5728\u306e\u691c\u7d22\u8a9e\u306b\u4e00\u81f4\u3059\u308b\u6a5f\u80fd\u3067\u3059\u3002"
  },
  "No matching example features.": {
    "fr": "Aucune fonctionnalite d'exemple correspondante.",
    "ar": "\u0644\u0627 \u062a\u0648\u062c\u062f \u0645\u064a\u0632\u0627\u062a \u062a\u062c\u0631\u064a\u0628\u064a\u0629 \u0645\u0637\u0627\u0628\u0642\u0629.",
    "ja": "\u4e00\u81f4\u3059\u308b\u30b5\u30f3\u30d7\u30eb\u6a5f\u80fd\u306f\u3042\u308a\u307e\u305b\u3093\u3002"
  },
  "Static assets are served from the resources directory through the same library API.": {
    "fr": "Les ressources statiques sont servies depuis le dossier resources via la meme API de bibliotheque.",
    "ar": "\u062a\u064f\u0642\u062f\u0651\u064e\u0645 \u0627\u0644\u0645\u0644\u0641\u0627\u062a \u0627\u0644\u062b\u0627\u0628\u062a\u0629 \u0645\u0646 \u0645\u062c\u0644\u062f resources \u0639\u0628\u0631 \u0648\u0627\u062c\u0647\u0629 \u0627\u0644\u0645\u0643\u062a\u0628\u0629 \u0646\u0641\u0633\u0647\u0627.",
    "ja": "\u9759\u7684\u30a2\u30bb\u30c3\u30c8\u3082\u540c\u3058\u30e9\u30a4\u30d6\u30e9\u30ea API \u3092\u901a\u3057\u3066 resources \u30c7\u30a3\u30ec\u30af\u30c8\u30ea\u304b\u3089\u914d\u4fe1\u3055\u308c\u307e\u3059\u3002"
  }
}
