@PACKAGE_INIT@

set(SYPHAX_WEB_ENABLE_TLS @SYPHAX_WEB_ENABLE_TLS@)
set(SYPHAX_WEB_ENABLE_CRYPTO @SYPHAX_WEB_ENABLE_CRYPTO@)
if(SYPHAX_WEB_ENABLE_TLS OR SYPHAX_WEB_ENABLE_CRYPTO)
    include(CMakeFindDependencyMacro)
    find_dependency(OpenSSL)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/syphax_webTargets.cmake")

check_required_components(syphax_web)
